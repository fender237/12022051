from PIL import Image
import matplotlib.pyplot as plt

# Пути к изображениям
images = [
    "photo1.jpg",
    "photo2.jpg",
    "photo3.jpg",
    "photo4.jpg",
    "photo5.jpg"
]

# Создаём окно для 5 фото
fig, axes = plt.subplots(1, 5, figsize=(15, 5))

# Выводим каждое фото
for ax, img_path in zip(axes, images):
    img = Image.open(img_path)
    ax.imshow(img)
    ax.axis("off")

plt.show()